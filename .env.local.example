# Best Direct Cremation — local environment example.
# Copy this file to `.env.local` and fill in the real values.
# .env.local is gitignored — never commit it.

# Sanity project (public — these are safe to expose)
NEXT_PUBLIC_SANITY_PROJECT_ID=80kiihr6
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity write token (SECRET — Editor-role token from sanity.io/manage/project/80kiihr6/api)
# Never commit. Only needed when running ingest scripts locally.
SANITY_API_WRITE_TOKEN=

# Apify token (SECRET — from console.apify.com/settings/integrations)
# Only needed for enrich-apify.ts, audit-competitors.ts, discover-keywords.ts
APIFY_API_TOKEN=

# Web3Forms key for the partner-with-us form (from web3forms.com)
NEXT_PUBLIC_WEB3FORMS_KEY=
